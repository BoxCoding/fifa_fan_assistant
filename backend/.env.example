# Kickoff backend configuration — copy to `.env` and fill in.
# `.env` is git-ignored; NEVER commit real secrets. This template must contain
# ONLY placeholders. Put real values in `.env` (local) or your host's env (prod).

# ---- Server ----
KICKOFF_PORT=8090
# Comma-separated allowed CORS origins (add your deployed frontend URL in prod).
# Do NOT use "*" — it is invalid when credentials are enabled. Any *.vercel.app
# origin is already allowed by default via KICKOFF_CORS_ORIGIN_REGEX.
KICKOFF_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
KICKOFF_DEMO_MODE=true

# ---- Auth ----
# Use a long random string in production (e.g. `openssl rand -hex 32`)
KICKOFF_SECRET_KEY=dev-insecure-change-me
KICKOFF_TOKEN_TTL_MIN=480

# ---- LLM (Gemini) ----
KICKOFF_LLM_PROVIDER=gemini
# Your Google Gemini API key — REQUIRED for AI responses. Keep it secret.
GEMINI_API_KEY=
KICKOFF_GEMINI_MODEL=gemini-2.5-flash-lite
# Alternative provider: set KICKOFF_LLM_PROVIDER=ollama and run Ollama locally
OLLAMA_HOST=http://localhost:11434
KICKOFF_LLM_MODEL=gemma2

# ---- Response cache ----
KICKOFF_CACHE_TTL_SEC=60
# Optional Vercel KV / Upstash Redis (shared cache across serverless instances).
# Vercel injects these when a KV store is linked; leave empty for in-memory cache.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ---- Firestore (persistent user store; optional) ----
# Install: pip install -r requirements-firestore.txt
FIRESTORE_PROJECT_ID=
# Local: path to the service-account JSON key file (keep the file OUT of git)
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json
# Serverless (Vercel): paste the full service-account JSON as a single line here
# in the Vercel dashboard — NEVER in this file.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIRESTORE_USERS_COLLECTION=users
