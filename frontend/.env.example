# Kickoff frontend configuration — copy to `.env` and fill in.
# `.env` is git-ignored. Vite only exposes vars prefixed with VITE_.

# Backend API base URL.
# Leave EMPTY for local dev — the Vite dev server proxies /api to :8090.
# In production set this to the deployed backend URL, e.g.
#   VITE_API_BASE=https://kickoff-api.vercel.app
VITE_API_BASE=
